{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pi Agent Web",
  "version": "0.79.1",
  "identifier": "works.earendil.pi.web",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:client",
    "devUrl": "http://127.0.0.1:3310",
    "frontendDist": "../dist-client"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Pi Agent Web",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "center": true,
        "fullscreen": false,
        "maximized": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
