    "@types/node": "22.19.19",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "@vitejs/plugin-react": "6.0.2",
    "autoprefixer": "10.4.21",
    "concurrently": "10.0.3",
    "postcss": "8.5.6",
    "tailwindcss": "4.1.6",
    "tsx": "4.22.1",
